# =============================================================================
# Master App – Variables d'environnement
# Copier vers .env.local et remplir les valeurs.
# =============================================================================

# --- Chemins (obligatoire en prod si différent de f:/Entreprises) ---
# Racine des dossiers entreprises (scanner, workers, etc.)
MASTER_ROOT_DIR=f:/Entreprises

# --- DRS Auto Detailing (Supabase) ---
DRS_SUPABASE_URL=
DRS_SUPABASE_SERVICE_ROLE_KEY=

# --- URLs des apps (pour les boutons "Ouvrir [App]" dans le dashboard) ---
# AUCLAIRE_APP_URL=https://auclaire.example.com
# DEFCON_APP_URL=https://defcon.example.com
# ANTIGRAVITY_APP_URL=https://viva-vegas.example.com
# DRS_APP_URL=https://drs.example.com

# --- Auclaire (Supabase) ---
AUCLAIRE_SUPABASE_URL=
AUCLAIRE_SUPABASE_SERVICE_ROLE_KEY=
# Ou clé anon si pas de service role: AUCLAIRE_SUPABASE_KEY=

# --- Defcon (Turso / LibSQL) ---
DEFCON_TURSO_URL=
DEFCON_TURSO_TOKEN=

# --- Antigravity / Viva Vegas (MongoDB) ---
ANTIGRAVITY_MONGODB_URI=

# --- Gemini / Google AI (résumé exécutif, board, workers) ---
GEMINI_API_KEY=
# Jarvis (assistant vocal) utilise une clé séparée :
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Cache (optionnel) ---
# TTL du cache des stats globales en secondes (défaut: 60)
# GLOBAL_STATS_CACHE_TTL_SEC=60

# --- Sécurité API (optionnel, recommandé en prod) ---
# Clé partagée pour protéger /api/jarvis et /api/webhooks (header: x-master-api-key)
MASTER_API_KEY=

# --- Stripe (worker rev-share) ---
STRIPE_SECRET_KEY=

# --- God-Eye (recherche omni – optionnel, si Supabase par app) ---
# AUCLAIRE_SUPABASE_SERVICE_KEY=
# DEFCON_SUPABASE_URL=
# DEFCON_SUPABASE_SERVICE_KEY=
# ANTIGRAVITY_SUPABASE_URL=
# ANTIGRAVITY_SUPABASE_SERVICE_KEY=
